{
  "name": "github-i18n",
  "version": "1.9.22",
  "description": "GitHub 中文本地化解决方案 - 用户脚本及自动化工具",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "build": "node build.cjs",
    "lint": "eslint src/ build.cjs collect-dict.cjs",
    "lint:fix": "eslint src/ build.cjs collect-dict.cjs --fix",
    "format": "prettier --write \"src/**/*.js\" \"build.cjs\" \"collect-dict.cjs\"",
    "format:check": "prettier --check \"src/**/*.js\" \"build.cjs\" \"collect-dict.cjs\"",
    "validate": "node -e \"const fs=require('fs');const path=require('path');const buildFile=path.join('build','GitHub_i18n.user.js');if(!fs.existsSync(buildFile)){console.error('构建产物不存在');process.exit(1)}const content=fs.readFileSync(buildFile,'utf8');if(content.length<1000){console.error('构建产物过小');process.exit(1)}console.log('验证通过');process.exit(0)\" && node --check build/GitHub_i18n.user.js && echo '语法检查通过'",
    "test": "npm run lint && npm run build && npm run validate",
    "clean": "node -e \"const fs=require('fs');const path=require('path');['build','dist','coverage'].forEach(dir=>{if(fs.existsSync(dir)){fs.rmSync(dir,{recursive:true});console.log('已清理:',dir)}})\"",
    "dict:collect": "node collect-dict.cjs"
  },
  "keywords": [
    "github",
    "i18n",
    "translation",
    "chinese",
    "localization",
    "userscript",
    "tampermonkey"
  ],
  "author": "Sut",
  "license": "GPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tanox/GitHub_i18n.git"
  },
  "bugs": {
    "url": "https://github.com/Tanox/GitHub_i18n/issues"
  },
  "homepage": "https://github.com/Tanox/GitHub_i18n#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.0.0",
    "globals": "^14.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
